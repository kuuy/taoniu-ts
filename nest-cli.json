{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/taoniu-ts/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/taoniu-ts/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/taoniu-ts",
  "projects": {
    "taoniu-ts": {
      "type": "application",
      "root": "apps/taoniu-ts",
      "entryFile": "main",
      "sourceRoot": "apps/taoniu-ts/src",
      "compilerOptions": {
        "tsConfigPath": "apps/taoniu-ts/tsconfig.app.json"
      }
    },
    "blog": {
      "type": "application",
      "root": "apps/blog",
      "entryFile": "main",
      "sourceRoot": "apps/blog/src",
      "compilerOptions": {
        "tsConfigPath": "apps/blog/tsconfig.app.json"
      }
    },
    "cryptos": {
      "type": "application",
      "root": "apps/cryptos",
      "entryFile": "main",
      "sourceRoot": "apps/cryptos/src",
      "compilerOptions": {
        "tsConfigPath": "apps/cryptos/tsconfig.app.json"
      }
    }
  }
}